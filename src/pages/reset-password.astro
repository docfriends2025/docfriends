---
import BaseLayout from '~/layouts/BaseLayout.astro';
export const prerender = false;
const token = Astro.url.searchParams.get('token') ?? '';
const hasToken = token.length >= 16;
---

<BaseLayout title="Set a new password — DocFriends" activeNav="/sign-in">
  <section class="rp">
    <div class="container-narrow">
      <header class="rp-head">
        <div class="eyebrow">Password help</div>
        <h1 class="h-display rp-title">Set a new password</h1>
      </header>

      {!hasToken ? (
        <div class="si-card">
          <div class="alert error">This reset link is missing or malformed. Request a fresh one.</div>
          <a href="/forgot-password" class="btn primary lg block" style="margin-top:16px">Request a reset link →</a>
        </div>
      ) : (
        <div class="si-card" data-card>
          <form data-reset-form>
            <input type="hidden" name="token" value={token} />
            <label for="rp-pw" class="field-label">New password <span class="opt">· at least 8 characters</span></label>
            <input id="rp-pw" name="password" type="password" class="input-line" placeholder="New password" autocomplete="new-password" minlength="8" required />
            <label for="rp-pw2" class="field-label" style="margin-top:16px">Confirm new password</label>
            <input id="rp-pw2" name="confirm" type="password" class="input-line" placeholder="Re-enter password" autocomplete="new-password" minlength="8" required />
            <button type="submit" class="btn primary lg block" style="margin-top:22px" data-submit>
              <span class="l-default">Set password &amp; sign in →</span>
              <span class="l-loading" hidden>Saving…</span>
            </button>
            <div class="alert error" data-form-error hidden style="margin-top:14px"></div>
          </form>
          <p class="muted tiny" style="text-align:center;margin-top:18px"><a href="/sign-in">← Back to sign in</a></p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .rp { padding-block: clamp(36px, 6vw, 72px); }
  .rp-head { text-align: center; max-width: 520px; margin: 0 auto 30px; }
  .rp-title { font-size: clamp(32px, 5vw, 42px); margin: 12px 0 14px; }
  .si-card { max-width: 460px; margin: 0 auto; background: var(--paper); border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 34px 32px; box-shadow: 0 24px 56px -26px rgba(26,34,56,.16); position: relative; }
  .si-card::before { content: ''; position: absolute; inset: -1px -1px auto; height: 4px; background: var(--accent); border-radius: var(--radius) var(--radius) 0 0; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-reset-form]');
  if (form) {
    const errorEl = form.querySelector<HTMLElement>('[data-form-error]')!;
    const submit = form.querySelector<HTMLButtonElement>('[data-submit]')!;
    const lDefault = submit.querySelector<HTMLElement>('.l-default')!;
    const lLoading = submit.querySelector<HTMLElement>('.l-loading')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.hidden = true;
      const fd = new FormData(form);
      const password = String(fd.get('password') || '');
      if (password !== String(fd.get('confirm') || '')) { errorEl.hidden = false; errorEl.textContent = 'Passwords do not match.'; return; }
      submit.disabled = true; lDefault.hidden = true; lLoading.hidden = false;
      try {
        const res = await fetch('/api/auth/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token: String(fd.get('token') || ''), password }) });
        const data = await res.json() as { ok?: boolean; error?: string; redirect?: string };
        if (res.ok && data.ok && data.redirect) { window.location.href = data.redirect; return; }
        throw new Error(data.error || 'Could not reset your password.');
      } catch (err) { errorEl.hidden = false; errorEl.textContent = err instanceof Error ? err.message : 'Network error.'; submit.disabled = false; lDefault.hidden = false; lLoading.hidden = true; }
    });
  }
</script>
