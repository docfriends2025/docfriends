---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getEnv, getDb, hasDb } from '~/lib/db';
import { getPackages } from '~/lib/content';
import { formatINR } from '~/lib/format';
import { SYMPTOM_GROUPS } from '~/lib/symptoms';

export const prerender = false;

const env = getEnv(Astro.locals);
const packages = await getPackages(env);
const fromPrice = formatINR(Math.min(...packages.map((p) => p.priceCents)));

// Which specialties actually have an active doctor — used so the result CTA never
// dead-ends at a checkout that can't be fulfilled. On any DB hiccup we fall back to
// `null`, which the client treats as "assume bookable" (preserves prior behavior).
let staffedSlugs: string[] | null = null;
if (hasDb(env)) {
  try {
    const r = await getDb(env).execute("SELECT DISTINCT specialty_slug FROM doctors WHERE active = 1 AND specialty_slug IS NOT NULL");
    staffedSlugs = r.rows.map((x) => String(x.specialty_slug));
  } catch (e) { console.error('finder: staffed query failed', e instanceof Error ? e.message : 'err'); }
}
---

<BaseLayout
  title="Find the right specialist — DocFriends"
  description="Tell us your symptom, answer a few questions, and we'll point you to the right specialist. Guidance only — not a diagnosis."
  activeNav="/find-a-specialist"
>
  <section class="finder" data-from-price={fromPrice} data-staffed={staffedSlugs === null ? '' : JSON.stringify(staffedSlugs)}>
    <!-- ── LEFT: symptom list ── -->
    <aside class="sym-pane">
      <div class="sym-head">
        <div class="h-title">Symptoms</div>
        <div class="sym-search">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="search" placeholder="Search 50+ symptoms…" data-search aria-label="Search symptoms" />
        </div>
      </div>
      <div class="sym-list" data-list>
        {SYMPTOM_GROUPS.map(([group, items], gi) => (
          <div class="sym-group" data-group data-open={gi < 4 ? "" : undefined}>
            <button type="button" class="sym-group-head" data-group-toggle>
              <span class="eyebrow tiny">{group}</span>
              <span class="caret">⌄</span>
            </button>
            <div class="sym-items">
              {items.map((s) => (
                <label class="sym-item" data-item data-name={s.toLowerCase()}>
                  <input type="checkbox" name="symptom" value={s} />
                  <span class="box"><svg viewBox="0 0 24 24" width="9" height="9" fill="none" stroke="#fff" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg></span>
                  <span class="lbl">{s}</span>
                </label>
              ))}
            </div>
          </div>
        ))}
        <p class="sym-empty faint tiny" data-empty hidden>No symptom matches that search.</p>
      </div>
      <div class="sym-foot faint tiny">Pick one or more symptoms. We'll ask a few questions and point you to the right specialist.</div>
    </aside>

    <!-- ── MAIN ── -->
    <div class="main-pane">
      <header class="main-head">
        <div>
          <div class="eyebrow">Symptom checker → specialist finder</div>
          <h1 class="h-display main-title">Find the right doctor for your symptom</h1>
        </div>
        <span class="chip">Not a diagnosis · guidance only</span>
      </header>

      <div class="main-body">
        <ol class="rail" data-rail>
          {['Symptom', 'A few questions', 'Likely causes', 'Your specialist'].map((s, i) => (
            <li class="rail-step" data-step={i}>
              <span class="rail-circle">{i + 1}</span><span class="rail-label">{s}</span>
            </li>
          ))}
        </ol>

        <!-- STAGE: questions (default — choosing a symptom on the left fills it in) -->
        <div class="stage" data-stage="questions">
          <div class="q-head">
            <div class="eyebrow tiny" data-q-eyebrow>Get started</div>
            <h2 class="q-title" data-q-title>Pick a symptom to begin</h2>
          </div>

          <div class="prog" data-q-progress hidden>
            <div class="prog-bar"><span class="prog-fill" data-q-fill></span></div>
            <span class="prog-count"><b data-q-count>0</b> of <b data-q-total>0</b> answered</span>
          </div>

          <div class="q-list" data-questions></div>

          <div class="q-foot" data-q-foot hidden>
            <span class="helper" data-q-helper></span>
            <button class="cta" data-to-results disabled>See likely causes →</button>
          </div>
        </div>

        <!-- STAGE: results -->
        <div class="stage" data-stage="results" hidden>
          <div class="results-grid">
            <div class="col-left">
              <div class="card recap" data-recap></div>
              <div class="card causes" data-causes></div>
            </div>
            <div class="col-right" data-reco></div>
          </div>
          <button class="btn ghost" data-restart style="margin-top:18px">↺ Start over</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .finder { display: grid; grid-template-columns: 290px 1fr; min-height: calc(100vh - 64px); }
  /* left */
  .sym-pane { border-right: 1px solid var(--line); background: var(--paper); display: flex; flex-direction: column; position: sticky; top: 64px; height: calc(100vh - 64px); }
  .sym-head { padding: 20px 18px 14px; border-bottom: 1px solid var(--line); }
  .sym-search { display: flex; align-items: center; gap: 8px; margin-top: 12px; padding: 9px 11px; border: 1px solid var(--line-strong); border-radius: 9px; color: var(--ink-light); }
  .sym-search input { border: 0; background: transparent; outline: none; font-size: 13px; width: 100%; color: var(--ink); }
  .sym-list { flex: 1; overflow: auto; padding: 8px 10px; }
  .sym-group { margin-bottom: 4px; }
  .sym-group-head { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 8px; background: none; border: 0; cursor: pointer; }
  .sym-group-head .caret { font-size: 13px; color: var(--ink-light); transition: transform .15s; }
  .sym-group:not([data-open]) .caret { transform: rotate(-90deg); }
  .sym-group:not([data-open]) .sym-items { display: none; }
  .sym-items { display: flex; flex-direction: column; gap: 1px; margin-bottom: 6px; }
  .sym-item { display: flex; align-items: center; gap: 8px; padding: 7px 10px; border-radius: 6px; cursor: pointer; color: var(--ink-soft); font-size: 13px; }
  .sym-item:hover { background: var(--paper-2); }
  .sym-item input { position: absolute; opacity: 0; pointer-events: none; }
  .sym-item .box { width: 15px; height: 15px; border-radius: 4px; border: 1.5px solid var(--line-strong); display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .sym-item .box svg { opacity: 0; }
  .sym-item:has(input:checked) { background: var(--ink); color: var(--paper); }
  .sym-item:has(input:checked) .box { background: var(--accent); border-color: var(--accent); }
  .sym-item:has(input:checked) .box svg { opacity: 1; }
  .sym-item:has(input:checked) .lbl { font-weight: 600; }
  .sym-foot { padding: 12px 16px; border-top: 1px solid var(--line); line-height: 1.5; }

  /* main */
  .main-pane { display: flex; flex-direction: column; min-width: 0; }
  .main-head { padding: 18px 32px; border-bottom: 1px solid var(--line); background: var(--paper); display: flex; justify-content: space-between; align-items: center; gap: 16px; }
  .main-title { font-size: 24px; margin-top: 2px; }
  .main-body { padding: 24px 32px 48px; }

  .rail { list-style: none; display: flex; align-items: center; gap: 0; padding: 0; margin: 0 0 26px; flex-wrap: wrap; }
  .rail-step { display: flex; align-items: center; gap: 8px; color: var(--ink-light); }
  .rail-step:not(:last-child)::after { content: ''; width: 42px; height: 1px; background: var(--line); margin: 0 14px; }
  .rail-circle { width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--line-strong); display: grid; place-items: center; font-size: 11px; }
  .rail-label { font-size: 13px; font-weight: 500; }
  .rail-step.done { color: var(--ink); } .rail-step.done .rail-circle { background: var(--ink); border-color: var(--ink); color: var(--paper); }
  .rail-step.active { color: var(--accent-deep); } .rail-step.active .rail-circle { background: var(--accent); border-color: var(--accent); color: #fff; }

  /* questions — static shell only. Question cards are injected at runtime, so
     their CSS lives in the <style is:global> block below. */
  .q-head { margin-bottom: 16px; }
  .q-title { font-family: var(--serif); font-weight: 400; font-size: clamp(22px, 3vw, 28px); margin-top: 2px; line-height: 1.1; }
  .prog { display: flex; align-items: center; gap: 14px; margin: 0 0 22px; max-width: 660px; }
  .prog-bar { flex: 1; height: 6px; border-radius: 99px; background: var(--paper-3); overflow: hidden; }
  .prog-fill { display: block; height: 100%; width: 0; background: var(--accent); border-radius: 99px; transition: width .35s cubic-bezier(.4,0,.2,1); }
  .prog-count { font-size: 12.5px; color: var(--ink-soft); white-space: nowrap; font-variant-numeric: tabular-nums; }
  .q-list { max-width: 660px; }
  .q-foot { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-top: 24px; max-width: 660px; flex-wrap: wrap; }
  .cta { display: inline-flex; align-items: center; gap: 8px; padding: 14px 26px; border-radius: 99px; border: none; background: var(--ink); color: var(--paper); font-family: var(--sans); font-size: 15px; font-weight: 600; cursor: pointer; transition: background .15s, opacity .15s, transform .12s; }
  .cta:disabled { opacity: .4; cursor: not-allowed; }
  .cta:not(:disabled):hover { background: #11192e; }
  .cta:not(:disabled):active { transform: translateY(1px); }

  /* results — static shell only (inner content is injected → global below) */
  .results-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 22px; align-items: start; }
  .recap, .causes { padding: 20px; margin-bottom: 16px; }

  @media (max-width: 980px) { .results-grid { grid-template-columns: 1fr; } }
  @media (max-width: 820px) {
    .finder { grid-template-columns: 1fr; }
    .sym-pane { position: static; height: auto; max-height: 320px; border-right: 0; border-bottom: 1px solid var(--line); }
    .main-head, .main-body { padding-inline: 20px; }
  }
</style>

<!-- These nodes are built at runtime via innerHTML in the page <script>, so they
     never get Astro's scoped data-astro-cid attribute — their CSS MUST be global.
     Namespaced under .finder so nothing leaks to other pages. -->
<style is:global>
  .finder .q-placeholder { font-size: 15px; line-height: 1.6; max-width: 560px; }

  /* progress / footer text use injected <b> children → keep global */
  .finder .prog-count b { color: var(--ink); font-weight: 600; }
  .finder .helper { font-size: 13px; color: var(--ink-soft); }
  .finder .helper b { color: var(--ink); font-weight: 600; }
  .finder .helper.ready { color: var(--success); }

  /* ── Questions: one card per question (ported from the redesign) ── */
  .finder .q { border: 1px solid var(--line); border-radius: var(--radius); background: var(--paper); padding: 22px 22px 24px; margin-bottom: 14px; transition: border-color .2s, box-shadow .2s; }
  .finder .q.answered { border-color: var(--line-strong); }
  .finder .q.current { box-shadow: 0 16px 40px -28px rgba(26,34,56,.28); }
  .finder .q-top { display: flex; align-items: baseline; gap: 12px; margin-bottom: 14px; }
  .finder .q-n { font-family: var(--mono); font-size: 11px; color: var(--accent); letter-spacing: .05em; padding-top: 2px; flex-shrink: 0; }
  .finder .q-text { font-size: 16.5px; font-weight: 600; line-height: 1.35; }
  .finder .q-tick { margin-left: auto; width: 20px; height: 20px; border-radius: 50%; background: var(--success-soft); color: var(--success); display: none; align-items: center; justify-content: center; flex-shrink: 0; }
  .finder .q.answered .q-tick { display: inline-flex; }

  .finder .opts { display: flex; flex-wrap: wrap; gap: 10px; }
  .finder .opt { flex: 1 1 auto; min-width: 120px; min-height: 52px; display: flex; align-items: center; justify-content: center; gap: 9px; text-align: center; padding: 12px 18px; border: 1px solid var(--line-strong); border-radius: 12px; background: var(--paper); font-size: 14.5px; font-weight: 500; color: var(--ink-soft); cursor: pointer; transition: all .15s; }
  .finder .opt:hover { border-color: var(--ink); color: var(--ink); }
  .finder .opt .mark { width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid var(--line-strong); flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; transition: all .15s; }
  .finder .opt .mark svg { opacity: 0; transform: scale(.6); transition: all .15s; }
  .finder .opt.sel { background: var(--ink); border-color: var(--ink); color: var(--paper); font-weight: 600; }
  .finder .opt.sel .mark { background: var(--accent); border-color: var(--accent); }
  .finder .opt.sel .mark svg { opacity: 1; transform: scale(1); }

  /* ── Safety / red-flag question, set apart ── */
  .finder .q.safety { border-left: 3px solid var(--warn); background: linear-gradient(90deg, var(--warn-soft), transparent 40%); }
  .finder .safety-flag { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--warn); margin-bottom: 10px; }
  .finder .q.safety .opt.sel[data-flag="yes"] { background: var(--danger); border-color: var(--danger); }
  .finder .q.safety .opt.sel[data-flag="yes"] .mark { background: #fff; border-color: #fff; }
  .finder .q.safety .opt.sel[data-flag="yes"] .mark svg { stroke: var(--danger); }
  .finder .safety-note { display: none; margin-top: 14px; padding: 12px 14px; border-radius: 10px; background: rgba(169,63,63,.08); color: var(--danger); font-size: 13px; line-height: 1.5; gap: 9px; }
  .finder .safety-note.show { display: flex; }
  .finder .safety-note svg { flex-shrink: 0; margin-top: 1px; }

  /* ── Results step ── */
  .finder .causes-title { font-family: var(--serif); font-size: 18px; line-height: 1.1; margin-bottom: 14px; }
  .finder .recap-row { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; margin-bottom: 10px; }
  .finder .recap-q { color: var(--ink-soft); font-size: 13.5px; flex: 1; }
  .finder .recap-a { font-size: 13.5px; font-weight: 500; text-align: right; max-width: 200px; }
  .finder .cause-row { margin-bottom: 12px; }
  .finder .cause-top { display: flex; justify-content: space-between; font-size: 13.5px; margin-bottom: 4px; }
  .finder .pbar { height: 7px; border-radius: 99px; background: var(--paper-2); overflow: hidden; }
  .finder .pbar > span { display: block; height: 100%; border-radius: 99px; }
  .finder .reco-card { padding: 22px; border: 1.5px solid var(--accent); border-radius: var(--radius); position: relative; background: var(--paper); }
  .finder .reco-badge { position: absolute; top: -11px; left: 22px; background: var(--accent); color: #fff; font-size: 11px; font-weight: 600; padding: 3px 12px; border-radius: 99px; }
  .finder .reco-top { display: flex; gap: 14px; align-items: center; margin: 12px 0; }
  .finder .reco-ic { width: 52px; height: 52px; border-radius: 12px; background: var(--ink); color: var(--paper); display: grid; place-items: center; flex-shrink: 0; }
  .finder .reco-name { font-size: 27px; font-family: var(--serif); }
  .finder .reco-why { font-size: 14px; line-height: 1.6; color: var(--ink-soft); }
  .finder .reco-meta { display: flex; gap: 6px; justify-content: center; margin-top: 12px; }
  .finder .alts { margin-top: 16px; }
  .finder .alt-card { display: flex; justify-content: space-between; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; margin-bottom: 10px; background: var(--paper); }
  .finder .alt-name { font-size: 14px; font-weight: 600; }
  .finder .alt-when { font-size: 12px; color: var(--ink-soft); margin-top: 1px; line-height: 1.4; }
  .finder .res-safety { margin-top: 16px; padding: 14px 16px; border-radius: 12px; background: rgba(169,63,63,.08); color: var(--danger); font-size: 13px; line-height: 1.55; display: flex; gap: 10px; }
  .finder .res-safety strong { font-weight: 700; }
  .finder .urgent-banner { margin-bottom: 18px; padding: 14px 16px; border-radius: 12px; background: var(--danger); color: #fff; font-size: 13.5px; line-height: 1.5; }

  /* ── Qualitative cause tones (seed-derived symptoms — words, never % ) ── */
  .finder .cause-row.qual { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 9px 0; border-bottom: 1px solid var(--line); }
  .finder .cause-row.qual:last-of-type { border-bottom: 0; }
  .finder .cause-name { font-size: 14px; }
  .finder .tone-badge { font-size: 11px; font-weight: 600; letter-spacing: .03em; padding: 3px 10px; border-radius: 99px; white-space: nowrap; }
  .finder .tone-badge.tone-common { background: var(--success-soft); color: var(--success); }
  .finder .tone-badge.tone-less-common { background: var(--warn-soft); color: var(--warn); }
  .finder .tone-badge.tone-serious-rare { background: rgba(169,63,63,.1); color: var(--danger); }

  /* ── Unstaffed specialty: guidance state, no checkout ── */
  .finder .reco-card.not-bookable { border-color: var(--line-strong); }
  .finder .reco-card.not-bookable .reco-badge { background: var(--ink-light); }
  .finder .expand-note { margin-top: 18px; padding: 16px; border-radius: 12px; background: var(--paper-2); border: 1px solid var(--line); }
  .finder .expand-h { font-weight: 600; font-size: 14.5px; margin-bottom: 6px; }
  .finder .expand-note p { font-size: 13px; color: var(--ink-soft); line-height: 1.55; margin-bottom: 12px; }

  /* ── Crisis state: support resources only, single column, no CTA ── */
  .finder .results-grid.crisis-mode { grid-template-columns: 1fr; }
  .finder .crisis-card { border: 1.5px solid var(--accent); border-radius: var(--radius); background: var(--paper); padding: 26px; max-width: 640px; }
  .finder .crisis-h { font-family: var(--serif); font-size: 24px; line-height: 1.2; margin-bottom: 14px; }
  .finder .crisis-body { font-size: 15px; line-height: 1.65; color: var(--ink-soft); margin-bottom: 16px; }
  .finder .crisis-immediate { font-size: 14px; line-height: 1.6; padding: 14px 16px; border-radius: 10px; background: rgba(169,63,63,.08); color: var(--danger); margin-bottom: 16px; }
  .finder .crisis-lines { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .finder .crisis-line { display: flex; flex-wrap: wrap; gap: 4px 12px; align-items: baseline; padding: 12px 14px; border: 1px solid var(--line-strong); border-radius: 10px; }
  .finder .crisis-line .cl-name { font-weight: 600; font-size: 14px; }
  .finder .crisis-line .cl-contact { font-family: var(--mono); font-size: 13px; color: var(--accent-deep); }
  .finder .crisis-line .cl-region { font-size: 11px; color: var(--ink-light); text-transform: uppercase; letter-spacing: .05em; }
  .finder .crisis-closing { font-size: 13.5px; color: var(--ink-soft); line-height: 1.6; }

  @media (max-width: 560px) { .finder .opt { flex: 1 1 100%; } }
</style>

<script>
  import { questionsFor, recommend, SYMPTOMS, CRISIS_RESOURCES } from '../lib/symptoms';

  const root = document.querySelector<HTMLElement>('.finder')!;
  const fromPrice = root.dataset.fromPrice ?? '$149';
  // Specialties with an active doctor. Empty string attr → null → "assume bookable".
  const staffedRaw = root.dataset.staffed ?? '';
  const staffed: Set<string> | null = staffedRaw ? new Set<string>(JSON.parse(staffedRaw)) : null;
  const isBookable = (slug: string | null): boolean => !!slug && (staffed === null || staffed.has(slug));
  const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const stages = {
    questions: root.querySelector<HTMLElement>('[data-stage="questions"]')!,
    results: root.querySelector<HTMLElement>('[data-stage="results"]')!,
  };
  const railSteps = Array.from(root.querySelectorAll<HTMLElement>('[data-step]'));
  const checks = Array.from(root.querySelectorAll<HTMLInputElement>('input[name="symptom"]'));
  const toR = root.querySelector<HTMLButtonElement>('[data-to-results]')!;
  const qEyebrow = root.querySelector<HTMLElement>('[data-q-eyebrow]')!;
  const qTitle = root.querySelector<HTMLElement>('[data-q-title]')!;
  const qProgress = root.querySelector<HTMLElement>('[data-q-progress]')!;
  const qFill = root.querySelector<HTMLElement>('[data-q-fill]')!;
  const qCount = root.querySelector<HTMLElement>('[data-q-count]')!;
  const qTotal = root.querySelector<HTMLElement>('[data-q-total]')!;
  const qFoot = root.querySelector<HTMLElement>('[data-q-foot]')!;
  const qHelper = root.querySelector<HTMLElement>('[data-q-helper]')!;

  let answers: Record<string, string> = {};

  const selectedNames = () => checks.filter((c) => c.checked).map((c) => c.value);
  const primaryOf = (sel: string[]) => sel.find((s) => SYMPTOMS[s]) ?? sel[0];

  function showStage(stage: 'questions' | 'results') {
    Object.entries(stages).forEach(([k, el]) => { el.hidden = k !== stage; });
  }
  function setRail(idx: number) {
    railSteps.forEach((el, i) => {
      el.classList.toggle('active', i === idx);
      el.classList.toggle('done', i < idx);
    });
  }

  // Picking a symptom on the left drives the questions directly — no interstitial.
  function syncSelection() {
    showStage('questions');
    if (selectedNames().length) { renderQuestions(); setRail(1); }
    else { showPlaceholder(); setRail(0); }
  }
  checks.forEach((c) => c.addEventListener('change', syncSelection));

  // group toggles
  root.querySelectorAll<HTMLButtonElement>('[data-group-toggle]').forEach((btn) =>
    btn.addEventListener('click', () => {
      const g = btn.closest<HTMLElement>('[data-group]')!;
      if (g.hasAttribute('data-open')) g.removeAttribute('data-open'); else g.setAttribute('data-open', '');
    }));

  // search
  const search = root.querySelector<HTMLInputElement>('[data-search]')!;
  const items = Array.from(root.querySelectorAll<HTMLElement>('[data-item]'));
  const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-group]'));
  const emptyMsg = root.querySelector<HTMLElement>('[data-empty]')!;
  search.addEventListener('input', () => {
    const q = search.value.trim().toLowerCase();
    let any = false;
    items.forEach((it) => { const m = !q || (it.dataset.name ?? '').includes(q); it.style.display = m ? '' : 'none'; if (m) any = true; });
    groups.forEach((g) => {
      const vis = Array.from(g.querySelectorAll<HTMLElement>('[data-item]')).some((i) => i.style.display !== 'none');
      g.style.display = vis ? '' : 'none';
      if (q && vis) g.setAttribute('data-open', '');
    });
    emptyMsg.hidden = any;
  });

  // ── questions ──
  const TICK = `<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>`;
  const MARK = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.5"><path d="M20 6 9 17l-5-5"/></svg>`;
  const SHIELD = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>`;
  const INFO = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v5M12 16h.01"/></svg>`;

  function showPlaceholder() {
    qEyebrow.textContent = 'Get started';
    qTitle.textContent = 'Pick a symptom to begin';
    qProgress.hidden = true;
    qFoot.hidden = true;
    toR.disabled = true;
    root.querySelector<HTMLElement>('[data-questions]')!.innerHTML =
      `<p class="q-placeholder muted">Choose one or more symptoms from the list on the left. We'll ask a few quick questions, then point you to the right specialist.</p>`;
  }

  function renderQuestions() {
    const sel = selectedNames();
    const primary = primaryOf(sel);
    const qs = questionsFor(primary);
    answers = {};
    qEyebrow.textContent = `About your ${primary.toLowerCase()}`;
    qTitle.textContent = 'A few quick questions';
    const urgentNote = SYMPTOMS[primary]?.redFlag
      ?? "That combination can be an emergency. We'll flag this case as urgent — and you may be advised to seek care now rather than wait for an opinion.";

    const wrap = root.querySelector<HTMLElement>('[data-questions]')!;
    wrap.innerHTML = qs.map((q, i) => {
      const isSafety = q.options.some((o) => o.redFlag);
      const opts = q.options.map((o) => {
        const flag = o.redFlag ? ' data-flag="yes"' : (isSafety ? ' data-flag="no"' : '');
        return `<button type="button" class="opt" data-opt="${encodeURIComponent(o.label)}"${flag}><span class="mark">${MARK}</span>${o.label}</button>`;
      }).join('');
      const head = `<div class="q-top"><span class="q-n">Q${i + 1}</span><span class="q-text">${q.q}</span><span class="q-tick">${TICK}</span></div>`;
      if (isSafety) {
        return `<div class="q safety" data-q="${q.id}" data-safety>
          <div class="safety-flag">${SHIELD} Safety check</div>
          ${head}
          <div class="opts">${opts}</div>
          <div class="safety-note" data-q-note>${INFO}<span>${urgentNote}</span></div>
        </div>`;
      }
      return `<div class="q" data-q="${q.id}">${head}<div class="opts">${opts}</div></div>`;
    }).join('');

    const cards = Array.from(wrap.querySelectorAll<HTMLElement>('[data-q]'));
    const updateProgress = () => {
      const answered = cards.filter((c) => c.classList.contains('answered')).length;
      const total = qs.length;
      qCount.textContent = String(answered);
      qTotal.textContent = String(total);
      qFill.style.width = (total ? Math.round((answered / total) * 100) : 0) + '%';
      cards.forEach((c) => c.classList.remove('current'));
      const next = cards.find((c) => !c.classList.contains('answered'));
      if (next) next.classList.add('current');
      const remaining = total - answered;
      toR.disabled = remaining > 0;
      if (remaining === 0) {
        qHelper.innerHTML = '✓ All set — here are your likely causes';
        qHelper.classList.add('ready');
      } else {
        qHelper.innerHTML = `Answer <b>${remaining}</b> more question${remaining > 1 ? 's' : ''} to continue`;
        qHelper.classList.remove('ready');
      }
    };

    cards.forEach((card) => {
      const opts = Array.from(card.querySelectorAll<HTMLButtonElement>('.opt'));
      opts.forEach((opt) => opt.addEventListener('click', () => {
        opts.forEach((o) => o.classList.remove('sel'));
        opt.classList.add('sel');
        card.classList.add('answered');
        answers[card.dataset.q!] = decodeURIComponent(opt.dataset.opt!);
        if (card.hasAttribute('data-safety')) {
          const note = card.querySelector<HTMLElement>('[data-q-note]');
          if (note) note.classList.toggle('show', opt.dataset.flag === 'yes');
        }
        updateProgress();
      }));
    });

    qProgress.hidden = false;
    qFoot.hidden = false;
    updateProgress();
  }

  // ── results ──
  const TONE_LABEL: Record<string, string> = { 'common': 'Common', 'less-common': 'Less common', 'serious-rare': 'Rare but serious' };

  function renderResults() {
    const sel = selectedNames();
    const rec = recommend(sel, answers);
    if (!rec) return;
    const grid = root.querySelector<HTMLElement>('.results-grid')!;

    // ── CRISIS: a self-harm answer was selected. Show support resources ONLY —
    //    no causes, no specialist, no booking/checkout CTA. ──
    if (rec.crisis) {
      grid.classList.add('crisis-mode');
      root.querySelector<HTMLElement>('[data-recap]')!.innerHTML = '';
      root.querySelector<HTMLElement>('[data-recap]')!.closest<HTMLElement>('.col-left')!.hidden = true;
      const c = CRISIS_RESOURCES;
      root.querySelector<HTMLElement>('[data-reco]')!.innerHTML = `
        <div class="crisis-card">
          <div class="crisis-h">${esc(c.heading)}</div>
          <p class="crisis-body">${esc(c.body)}</p>
          <div class="crisis-immediate"><strong>If you are in immediate danger:</strong> ${esc(c.immediate)}</div>
          <div class="crisis-lines">
            ${c.lines.map((l) => `<div class="crisis-line"><span class="cl-name">${esc(l.name)}</span><span class="cl-contact">${esc(l.contact)}</span>${l.region ? `<span class="cl-region">${esc(l.region)}</span>` : ''}</div>`).join('')}
          </div>
          <p class="crisis-closing">${esc(c.closing)}</p>
        </div>`;
      return;
    }
    grid.classList.remove('crisis-mode');
    root.querySelector<HTMLElement>('[data-recap]')!.closest<HTMLElement>('.col-left')!.hidden = false;

    const qs = questionsFor(rec.primarySymptom);
    root.querySelector<HTMLElement>('[data-recap]')!.innerHTML = `
      <div class="eyebrow tiny" style="margin-bottom:12px">We asked · you answered — <b>${esc(rec.primarySymptom)}</b></div>
      ${qs.map((q) => `<div class="recap-row"><span class="recap-q">${esc(q.q)}</span><span class="recap-a">${esc(answers[q.id] ?? '—')}</span></div>`).join('')}`;

    // Causes: seed-derived symptoms carry a clinical tone → show a WORD badge, never a
    // fabricated percentage. Existing symptoms keep their %-match bars.
    const qualitative = rec.causes.length > 0 && rec.causes.every((c) => !!c.clinicalTone);
    root.querySelector<HTMLElement>('[data-causes]')!.innerHTML = `
      <div class="eyebrow tiny" style="margin-bottom:4px">${qualitative ? 'Possible causes' : 'Narrowed to'}</div>
      <div class="causes-title">${rec.causes.length} ${qualitative ? 'to consider' : 'most likely'}</div>
      ${rec.causes.map((c) => {
        if (c.clinicalTone) {
          return `<div class="cause-row qual"><span class="cause-name">${esc(c.name)}</span><span class="tone-badge tone-${c.clinicalTone}">${TONE_LABEL[c.clinicalTone]}</span></div>`;
        }
        const color = c.tone === 'green' ? 'var(--success)' : c.tone === 'yellow' ? 'var(--warn)' : 'var(--ink-light)';
        return `<div class="cause-row"><div class="cause-top"><span>${esc(c.name)}</span><span class="muted">${c.pct}% match</span></div><div class="pbar"><span style="width:${c.pct}%;background:${color}"></span></div></div>`;
      }).join('')}
      <div class="faint tiny" style="margin-top:12px;line-height:1.5">These are possibilities, not a diagnosis. A specialist confirms.</div>`;

    const sp = rec.specialist;
    const symptomSeed = selectedNames().join(', ');
    const intakeHref = (slug: string | null) => {
      const p = new URLSearchParams();
      if (symptomSeed) p.set('symptom', symptomSeed);
      if (slug) p.set('specialty', slug);
      const qstr = p.toString();
      return qstr ? `/?${qstr}#start` : '/#start';
    };
    const bookable = isBookable(sp.specialtySlug);
    // Primary action: book when staffed; otherwise a "we're expanding" state with a
    // lightweight interest capture — NEVER a checkout that can't be fulfilled.
    const primaryAction = bookable
      ? `<a href="${intakeHref(sp.specialtySlug)}" class="btn primary lg" style="margin-top:18px;width:100%;justify-content:center">Get an opinion from a ${esc(sp.label.toLowerCase())} →</a>
         <div class="reco-meta"><span class="tiny muted">Specialists on DocFriends · from</span><span class="tiny" style="font-weight:600">${fromPrice}</span></div>`
      : `<div class="expand-note">
           <div class="expand-h">We're expanding into ${esc(sp.label.toLowerCase())} care</div>
           <p>We don't have a ${esc(sp.label.toLowerCase())} available to book just yet. The guidance above still stands — and if it's urgent, please act on the safety note rather than wait.</p>
           <a class="btn ghost sm" href="mailto:help@docfriends.com?subject=${encodeURIComponent('Interest: ' + sp.label)}&body=${encodeURIComponent("I'd like a " + sp.label + ' on DocFriends.')}">Notify me when it's available →</a>
         </div>`;

    root.querySelector<HTMLElement>('[data-reco]')!.innerHTML = `
      ${rec.urgent ? `<div class="urgent-banner"><strong>This may need urgent care.</strong> ${esc(rec.redFlag ?? 'Based on your answers, please seek prompt medical attention rather than waiting for an opinion.')}</div>` : ''}
      <div class="reco-card${bookable ? '' : ' not-bookable'}">
        <span class="reco-badge">${bookable ? 'start here' : 'guidance'}</span>
        <div class="eyebrow tiny" style="color:var(--accent)">Recommended specialist</div>
        <div class="reco-top">
          <span class="reco-ic"><svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 3v6a6 6 0 0 0 12 0V3"/><path d="M6 3H4m2 0h2m8 0h2m-2 0h-2"/><path d="M12 15v3a4 4 0 0 0 8 0v-1"/><circle cx="20" cy="14" r="2"/></svg></span>
          <div><div class="reco-name">${esc(sp.label)}</div><div class="muted" style="font-size:13.5px">${esc(sp.blurb)}</div></div>
        </div>
        <div class="reco-why">${esc(SYMPTOMS[rec.primarySymptom]?.rationale ?? `A ${sp.label.toLowerCase()} is the right specialist to assess this.`)}</div>
        ${primaryAction}
      </div>
      ${rec.alternatives.length ? `<div class="alts"><div class="eyebrow tiny" style="margin-bottom:10px">If symptoms change, also consider</div>
        ${rec.alternatives.map((a) => {
          const altBook = isBookable(a.specialist.specialtySlug);
          const altCta = altBook
            ? `<a href="${intakeHref(a.specialist.specialtySlug)}" class="btn ghost sm">View →</a>`
            : `<span class="chip tiny" style="white-space:nowrap">not yet bookable</span>`;
          return `<div class="alt-card"><div><div class="alt-name">${esc(a.specialist.label)}</div><div class="alt-when">${esc(a.when)}</div></div>${altCta}</div>`;
        }).join('')}</div>` : ''}
      ${rec.redFlag && !rec.urgent ? `<div class="res-safety"><strong>!</strong><div>${esc(rec.redFlag)}</div></div>` : ''}`;
  }

  // wiring
  toR.addEventListener('click', () => { renderResults(); showStage('results'); setRail(3); });
  root.querySelector('[data-restart]')!.addEventListener('click', () => {
    checks.forEach((c) => { c.checked = false; });
    answers = {}; syncSelection();
  });

  syncSelection();
</script>
