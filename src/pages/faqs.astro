---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getEnv } from '~/lib/db';
import { getFaqs, FAQ_CATEGORIES } from '~/lib/content';

export const prerender = false;

const faqs = await getFaqs(getEnv(Astro.locals));
const grouped = FAQ_CATEGORIES.map((c) => ({ ...c, items: faqs.filter((f) => f.category === c.slug) }));
---

<BaseLayout title="FAQs — DocFriends" description="Common questions about second opinions, doctors, and billing." activeNav="/faqs">
  <section class="faq">
    <div class="container">
      <header class="faq-head">
        <div>
          <div class="eyebrow">Help center</div>
          <h1 class="h-display faq-title">Questions, <em>asked often.</em></h1>
          <p class="muted">Can't find yours? <a href="/contact" class="ul">Email support</a>.</p>
        </div>
        <div class="faq-search">
          <span class="search-ico">⌕</span>
          <input type="search" class="input-box" placeholder="Search the help center…" data-faq-search aria-label="Search FAQs" />
        </div>
      </header>

      <div class="faq-body">
        <aside class="faq-nav">
          {FAQ_CATEGORIES.map((c, i) => (
            <a href={`#${c.slug}`} class:list={['faq-nav-link', { active: i === 0 }]}>{c.label}</a>
          ))}
          <div class="faq-nav-sep"></div>
          <span class="faint tiny">Can't find it?</span>
          <a href="/contact" class="faq-nav-link contact">Contact support →</a>
        </aside>

        <div class="faq-groups" data-faq-groups>
          {grouped.map((group) => (
            <section id={group.slug} class="faq-group" data-group>
              <h2 class="h-display group-title">{group.label}</h2>
              <div class="accordion">
                {group.items.map((f, idx) => (
                  <details class="acc-item" open={idx === 0} data-faq data-text={`${f.question} ${f.answer}`.toLowerCase()}>
                    <summary><span>{f.question}</span><span class="acc-mark" aria-hidden="true"></span></summary>
                    <div class="acc-body"><p>{f.answer}</p></div>
                  </details>
                ))}
              </div>
            </section>
          ))}
          <p class="faq-empty muted" data-empty hidden>No questions match that search. Try <a href="/contact" class="ul">emailing support</a>.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq { padding-block: clamp(36px, 5vw, 60px); }
  .faq-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 32px; flex-wrap: wrap; margin-bottom: 44px; }
  .faq-title { font-size: clamp(36px, 5vw, 52px); margin: 12px 0 12px; }
  .ul { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .faq-search { position: relative; min-width: 300px; flex: 1; max-width: 360px; }
  .search-ico { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--ink-light); font-size: 17px; }
  .faq-search .input-box { padding-left: 38px; border-radius: 99px; }

  .faq-body { display: grid; grid-template-columns: 220px 1fr; gap: 56px; align-items: start; }
  .faq-nav { position: sticky; top: 90px; display: flex; flex-direction: column; gap: 4px; }
  .faq-nav-link { padding: 8px 14px; font-size: 14px; font-weight: 500; color: var(--ink-soft); border-left: 2px solid transparent; border-radius: 0 6px 6px 0; }
  .faq-nav-link:hover { color: var(--ink); background: var(--paper-2); }
  .faq-nav-link.active { color: var(--ink); border-left-color: var(--accent); font-weight: 600; }
  .faq-nav-link.contact { color: var(--accent); padding-top: 4px; }
  .faq-nav-sep { height: 1px; background: var(--line); margin: 14px 14px; }

  .faq-group { margin-bottom: 46px; scroll-margin-top: 90px; }
  .group-title { font-size: 26px; margin-bottom: 16px; }
  .accordion { display: flex; flex-direction: column; gap: 10px; }
  .acc-item { border: 1px solid var(--line); border-radius: 12px; background: var(--paper); overflow: hidden; transition: border-color .15s; }
  .acc-item[open] { border-color: var(--line-strong); }
  .acc-item summary { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 18px 22px; font-size: 15.5px; font-weight: 600; cursor: pointer; list-style: none; }
  .acc-item summary::-webkit-details-marker { display: none; }
  .acc-mark { position: relative; width: 14px; height: 14px; flex-shrink: 0; }
  .acc-mark::before, .acc-mark::after { content: ''; position: absolute; background: var(--accent); transition: opacity .2s, transform .2s; }
  .acc-mark::before { top: 6px; left: 0; width: 14px; height: 1.6px; }
  .acc-mark::after  { top: 0; left: 6.2px; width: 1.6px; height: 14px; }
  .acc-item[open] .acc-mark::after { opacity: 0; transform: scaleY(0); }
  .acc-body { padding: 0 22px 20px; }
  .acc-body p { color: var(--ink-soft); font-size: 14.5px; line-height: 1.65; max-width: 60ch; }

  @media (max-width: 820px) { .faq-body { grid-template-columns: 1fr; gap: 28px; } .faq-nav { position: static; flex-direction: row; flex-wrap: wrap; } .faq-nav-sep, .faq-nav .tiny { display: none; } }
</style>

<script>
  const search = document.querySelector<HTMLInputElement>('[data-faq-search]');
  const items = Array.from(document.querySelectorAll<HTMLDetailsElement>('[data-faq]'));
  const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-group]'));
  const empty = document.querySelector<HTMLParagraphElement>('[data-empty]');
  search?.addEventListener('input', () => {
    const q = search.value.trim().toLowerCase();
    let any = false;
    items.forEach((it) => {
      const match = !q || (it.dataset.text ?? '').includes(q);
      it.style.display = match ? '' : 'none';
      if (match) { any = true; if (q) it.open = true; }
    });
    groups.forEach((g) => {
      const visible = Array.from(g.querySelectorAll<HTMLDetailsElement>('[data-faq]')).some((i) => i.style.display !== 'none');
      g.style.display = visible ? '' : 'none';
    });
    if (empty) empty.hidden = any;
  });

  // active sidebar link on scroll
  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('.faq-nav-link[href^="#"]'));
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        links.forEach((l) => l.classList.toggle('active', l.getAttribute('href') === `#${e.target.id}`));
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });
  groups.forEach((g) => io.observe(g));
</script>
