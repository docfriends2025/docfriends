---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getEnv } from '~/lib/db';
import { getSpecialties } from '~/lib/content';

export const prerender = false;
const specialties = await getSpecialties(getEnv(Astro.locals));
---

<BaseLayout title="Apply to join — DocFriends for physicians" description="Board-certified specialists: apply to review second-opinion cases on DocFriends.">
  <section class="apply">
    <div class="container-narrow">
      <header class="ap-head">
        <div class="eyebrow">For physicians</div>
        <h1 class="h-display ap-title">Join the DocFriends panel</h1>
        <p class="ap-lead muted">Apply to review second-opinion cases. We verify every applicant's credentials before approval — your license details are seen only by our review team, never by patients.</p>
      </header>

      <div class="ap-card" data-card-default>
        <form data-apply-form>
          <div class="grp">Your account</div>
          <label class="field-label" for="ap-name">Full name</label>
          <input id="ap-name" name="name" class="input-box" placeholder="Dr. Jane Okafor" autocomplete="name" maxlength="120" required />
          <label class="field-label" for="ap-email">Email</label>
          <input id="ap-email" name="email" type="email" class="input-box" placeholder="you@hospital.org" autocomplete="email" required />
          <label class="field-label" for="ap-pw">Password <span class="opt">· at least 8 characters</span></label>
          <input id="ap-pw" name="password" type="password" class="input-box" placeholder="Create a password" autocomplete="new-password" minlength="8" required />

          <div class="grp">Professional profile</div>
          <label class="field-label" for="ap-spec">Specialty</label>
          <select id="ap-spec" name="specialty" class="input-box" required>
            <option value="">Choose your specialty…</option>
            {specialties.map((s) => <option value={s.slug}>{s.name}</option>)}
          </select>
          <div class="two">
            <div><label class="field-label" for="ap-sub">Subspecialty <span class="opt">(optional)</span></label><input id="ap-sub" name="subspecialty" class="input-box" maxlength="80" placeholder="e.g. Interventional" /></div>
            <div><label class="field-label" for="ap-years">Years in practice</label><input id="ap-years" name="years" type="number" min="0" max="80" class="input-box" placeholder="12" /></div>
          </div>
          <div class="two">
            <div><label class="field-label" for="ap-hosp">Hospital / clinic</label><input id="ap-hosp" name="hospital" class="input-box" maxlength="120" placeholder="NYU Langone" /></div>
            <div><label class="field-label" for="ap-loc">Location</label><input id="ap-loc" name="location" class="input-box" maxlength="120" placeholder="New York, US" /></div>
          </div>
          <label class="field-label" for="ap-bio">Short bio <span class="opt">(optional)</span></label>
          <textarea id="ap-bio" name="bio" class="input-box" rows="3" maxlength="1000" placeholder="A sentence or two on your background and approach."></textarea>

          <div class="grp">Verification <span class="grp-note faint">· seen only by our review team</span></div>
          <div class="two">
            <div><label class="field-label" for="ap-lic">License / registration number</label><input id="ap-lic" name="license_number" class="input-box" maxlength="80" required /></div>
            <div><label class="field-label" for="ap-auth">Issuing authority</label><input id="ap-auth" name="license_authority" class="input-box" maxlength="120" placeholder="Council / board / state / country" required /></div>
          </div>
          <label class="field-label" for="ap-reg">Registry ID <span class="opt">(optional, e.g. NPI)</span></label>
          <input id="ap-reg" name="registry_id" class="input-box" maxlength="80" />
          <label class="field-label" for="ap-note">Anything else for the reviewers? <span class="opt">(optional)</span></label>
          <textarea id="ap-note" name="credential_note" class="input-box" rows="2" maxlength="1000"></textarea>
          <p class="faint tiny" style="margin-top:8px">Credential document upload is coming soon — for now, the text above is enough to start your review.</p>

          <button type="submit" class="btn primary lg block" style="margin-top:22px" data-submit>
            <span class="l-default">Submit application →</span>
            <span class="l-loading" hidden>Submitting…</span>
          </button>
          <div class="alert error" data-form-error hidden style="margin-top:14px"></div>
        </form>
        <p class="haveacct muted tiny">Already applied or have an account? <a href="/sign-in">Sign in</a></p>
      </div>

      <div class="ap-card" data-card-sent hidden>
        <div class="sent-ico">✉</div>
        <h2 class="h-display sent-h">Application received.</h2>
        <p class="muted">Confirm your email at <strong data-sent-email></strong> to finish — then sign in to track your application. Our team reviews credentials and you'll hear back by email once you're approved.</p>
        <div data-dev-fallback hidden style="margin-top:18px">
          <div class="alert dev"><strong>DEV MODE</strong> — no email provider. Click to confirm + continue.</div>
          <a href="#" class="btn primary lg block" data-dev-link style="margin-top:12px">Confirm &amp; continue →</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .apply { padding-block: clamp(28px, 5vw, 56px); }
  .ap-head { max-width: 620px; margin: 0 auto 28px; text-align: center; }
  .ap-title { font-size: clamp(32px, 5vw, 44px); margin: 10px 0 12px; }
  .ap-lead { font-size: 15px; line-height: 1.6; }
  .ap-card { max-width: 600px; margin: 0 auto; background: var(--paper); border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 30px 30px; box-shadow: 0 24px 56px -26px rgba(26,34,56,.16); position: relative; }
  .ap-card::before { content: ''; position: absolute; inset: -1px -1px auto; height: 4px; background: var(--accent); border-radius: var(--radius) var(--radius) 0 0; }
  .grp { font-family: var(--serif); font-size: 18px; margin: 22px 0 6px; padding-top: 14px; border-top: 1px solid var(--line); }
  .grp:first-of-type { margin-top: 0; padding-top: 0; border-top: 0; }
  .grp-note { font-family: var(--sans); font-size: 12px; font-weight: 400; }
  .two { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  select.input-box { cursor: pointer; }
  .haveacct { text-align: center; margin-top: 18px; }
  .sent-ico { font-family: var(--serif); font-size: 46px; color: var(--accent); line-height: 1; margin-bottom: 14px; }
  .sent-h { font-size: 28px; margin-bottom: 10px; }
  @media (max-width: 560px) { .two { grid-template-columns: 1fr; } }
</style>

<script>
  const root = document.querySelector('.apply')!;
  const form = root.querySelector<HTMLFormElement>('[data-apply-form]')!;
  const cardDefault = root.querySelector<HTMLElement>('[data-card-default]')!;
  const cardSent = root.querySelector<HTMLElement>('[data-card-sent]')!;
  const errorEl = form.querySelector<HTMLElement>('[data-form-error]')!;
  const submit = form.querySelector<HTMLButtonElement>('[data-submit]')!;
  const lDefault = submit.querySelector<HTMLElement>('.l-default')!;
  const lLoading = submit.querySelector<HTMLElement>('.l-loading')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true; submit.disabled = true; lDefault.hidden = true; lLoading.hidden = false;
    const fd = new FormData(form);
    const payload: Record<string, string> = {};
    for (const [k, v] of fd.entries()) payload[k] = String(v).trim();
    try {
      const res = await fetch('/api/physician/apply', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      const data = await res.json() as { ok?: boolean; error?: string; devLink?: string };
      if (!res.ok || !data.ok) throw new Error(data.error || 'Could not submit your application.');
      root.querySelector<HTMLElement>('[data-sent-email]')!.textContent = String(fd.get('email') || '');
      cardDefault.hidden = true; cardSent.hidden = false; window.scrollTo(0, 0);
      if (data.devLink) { const df = root.querySelector<HTMLElement>('[data-dev-fallback]')!; const dl = root.querySelector<HTMLAnchorElement>('[data-dev-link]')!; df.hidden = false; dl.href = data.devLink; }
    } catch (err) { errorEl.hidden = false; errorEl.textContent = err instanceof Error ? err.message : 'Network error.'; }
    finally { submit.disabled = false; lDefault.hidden = false; lLoading.hidden = true; }
  });
</script>
