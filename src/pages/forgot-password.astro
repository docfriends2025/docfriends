---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { HOME_FOR_ROLE } from '~/lib/site';
export const prerender = false;
if (Astro.locals.user) return Astro.redirect(HOME_FOR_ROLE[Astro.locals.user.role] ?? '/dashboard');
---

<BaseLayout title="Reset your password — DocFriends" activeNav="/sign-in">
  <section class="fp">
    <div class="container-narrow">
      <header class="fp-head">
        <div class="eyebrow">Password help</div>
        <h1 class="h-display fp-title">Reset your password</h1>
        <p class="fp-lead muted">Enter your email and we'll send a link to set a new password.</p>
      </header>

      <div class="si-card" data-card-default>
        <form data-forgot-form>
          <label for="fp-email" class="field-label">Email</label>
          <input id="fp-email" name="email" type="email" class="input-line" placeholder="you@email.com" autocomplete="email" required />
          <button type="submit" class="btn primary lg block" style="margin-top:22px" data-submit>
            <span class="l-default">Send reset link →</span>
            <span class="l-loading" hidden>Sending…</span>
          </button>
          <div class="alert error" data-form-error hidden style="margin-top:14px"></div>
        </form>
        <p class="muted tiny" style="text-align:center;margin-top:18px"><a href="/sign-in">← Back to sign in</a></p>
      </div>

      <div class="si-card" data-card-sent hidden>
        <div class="sent-ico">✉</div>
        <h2 class="h-display sent-h">Check your email.</h2>
        <p class="muted">If an account exists for <strong data-sent-email></strong>, we've sent a link to reset your password. It expires in 1 hour and can be used once.</p>
        <p class="faint tiny" style="margin-top:16px"><a href="/sign-in">← Back to sign in</a></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .fp { padding-block: clamp(36px, 6vw, 72px); }
  .fp-head { text-align: center; max-width: 520px; margin: 0 auto 30px; }
  .fp-title { font-size: clamp(32px, 5vw, 42px); margin: 12px 0 14px; }
  .fp-lead { font-size: 15px; line-height: 1.6; }
  .si-card { max-width: 460px; margin: 0 auto; background: var(--paper); border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 34px 32px; box-shadow: 0 24px 56px -26px rgba(26,34,56,.16); position: relative; }
  .si-card::before { content: ''; position: absolute; inset: -1px -1px auto; height: 4px; background: var(--accent); border-radius: var(--radius) var(--radius) 0 0; }
  .sent-ico { font-family: var(--serif); font-size: 46px; color: var(--accent); line-height: 1; margin-bottom: 14px; }
  .sent-h { font-size: 28px; margin-bottom: 10px; }
</style>

<script>
  const root = document.querySelector('.fp')!;
  const form = root.querySelector<HTMLFormElement>('[data-forgot-form]')!;
  const cardDefault = root.querySelector<HTMLElement>('[data-card-default]')!;
  const cardSent = root.querySelector<HTMLElement>('[data-card-sent]')!;
  const errorEl = form.querySelector<HTMLElement>('[data-form-error]')!;
  const submit = form.querySelector<HTMLButtonElement>('[data-submit]')!;
  const lDefault = submit.querySelector<HTMLElement>('.l-default')!;
  const lLoading = submit.querySelector<HTMLElement>('.l-loading')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.hidden = true; submit.disabled = true; lDefault.hidden = true; lLoading.hidden = false;
    const email = String(new FormData(form).get('email') || '').trim();
    try {
      const res = await fetch('/api/auth/forgot', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
      const data = await res.json() as { ok?: boolean; error?: string };
      if (!res.ok || !data.ok) throw new Error(data.error || 'Something went wrong.');
      root.querySelector<HTMLElement>('[data-sent-email]')!.textContent = email;
      cardDefault.hidden = true; cardSent.hidden = false;
    } catch (err) { errorEl.hidden = false; errorEl.textContent = err instanceof Error ? err.message : 'Network error.'; }
    finally { submit.disabled = false; lDefault.hidden = false; lLoading.hidden = true; }
  });
</script>
