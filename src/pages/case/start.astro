---
// Screen 7 — Sign up. Holds the anonymous case in a real account, then hands off
// to checkout. Already signed in? Skip straight to package & payment.
import BaseLayout from '~/layouts/BaseLayout.astro';
import FlowSteps from '~/components/FlowSteps.astro';
import CaseRail from '~/components/CaseRail.astro';
import { getEnv } from '~/lib/db';
import { loadDraft } from '~/lib/cases';

export const prerender = false;

if (Astro.locals.user) return Astro.redirect('/case/checkout');

const env = getEnv(Astro.locals);
const draftId = Astro.cookies.get('df_draft')?.value ?? null;
const draft = await loadDraft(env, draftId);
const NEXT = '/case/checkout';
---

<BaseLayout title="Create your account — DocFriends" chrome={true}>
  <section class="flow">
    <div class="container">
      <FlowSteps current={2} />

      <div class="flow-grid">
        <div class="flow-main">
          <div class="eyebrow">Step 2 of 3</div>
          <h1 class="h-display flow-title">Create your account <em>to continue.</em></h1>
          <p class="muted lead">We hold your case in a secure account so only you and your assigned doctors ever see it. No passwords — we email you a one-tap link.</p>

          <div class="su-card" data-card-default>
            <div class="social-row">
              <button type="button" class="social-btn" data-soon="Google sign-up is coming soon — use your email below for now.">
                <span class="s-ico">G</span> Continue with Google
              </button>
              <button type="button" class="social-btn" data-soon="Apple sign-up is coming soon — use your email below for now.">
                <span class="s-ico"></span> Continue with Apple
              </button>
            </div>
            <div class="or"><span>or continue with email</span></div>

            <form data-signup-form>
              <label for="su-name" class="field-label">Your name <span class="opt">(optional)</span></label>
              <input id="su-name" name="name" type="text" class="input-line" placeholder="Jane Okafor" autocomplete="name" maxlength="120" />
              <label for="su-email" class="field-label" style="margin-top:16px">Your email</label>
              <input id="su-email" name="email" type="email" class="input-line" placeholder="you@email.com" autocomplete="email" required />
              <input type="hidden" name="next" value={NEXT} />
              <button type="submit" class="btn primary lg block" style="margin-top:22px" data-submit>
                <span class="l-default">Create account &amp; continue →</span>
                <span class="l-loading" hidden>Sending…</span>
              </button>
              <div class="alert error" data-form-error hidden style="margin-top:14px"></div>
            </form>

            <div class="trust"><span class="check">✓</span><span class="faint tiny">No passwords · No spam · Delete account anytime</span></div>
          </div>

          <!-- Sent state -->
          <div class="su-card" data-card-sent hidden>
            <div class="sent-ico">✉</div>
            <h2 class="h-display sent-h">Check your email.</h2>
            <p class="muted">We sent a sign-in link to <strong data-sent-email></strong>. It works once, expires in 15 minutes, and drops you straight onto checkout — your case comes with you.</p>
            <div data-dev-fallback hidden style="margin-top:18px">
              <div class="alert dev"><strong>DEV MODE</strong> — no email provider configured. Click below to continue. Set <code>RESEND_API_KEY</code> to send real email.</div>
              <a href="#" class="btn primary lg block" data-dev-link style="margin-top:12px">Click to continue →</a>
            </div>
            <button type="button" class="btn ghost block" data-back style="margin-top:16px">← Use a different email</button>
          </div>

          <a href="/" class="back-link faint tiny">← Edit my case</a>
        </div>

        <CaseRail draft={draft} />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .flow { padding-block: clamp(28px, 4vw, 48px); }
  .flow-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(28px, 4vw, 56px); align-items: start; }
  .flow-title { font-size: clamp(32px, 4.5vw, 46px); margin: 12px 0 10px; }
  .lead { max-width: 46ch; font-size: 15px; line-height: 1.6; }

  .su-card { max-width: 460px; margin: 26px 0 0; background: var(--paper); border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 30px 28px; box-shadow: 0 24px 56px -26px rgba(26,34,56,.16); position: relative; }
  .su-card::before { content: ''; position: absolute; inset: -1px -1px auto; height: 4px; background: var(--accent); border-radius: var(--radius) var(--radius) 0 0; }
  .social-row { display: flex; flex-direction: column; gap: 10px; }
  .social-btn { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 13px; border: 1px solid var(--line-strong); border-radius: 10px; background: var(--paper); font-size: 14.5px; font-weight: 500; cursor: pointer; transition: border-color .15s, background .15s; }
  .social-btn:hover { border-color: var(--ink); background: var(--paper-2); }
  .s-ico { width: 20px; height: 20px; display: grid; place-items: center; font-weight: 700; font-family: var(--serif); }
  .or { display: flex; align-items: center; gap: 14px; margin: 20px 0; color: var(--ink-light); font-size: 12px; }
  .or::before, .or::after { content: ''; flex: 1; height: 1px; background: var(--line); }
  .trust { margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--line); display: flex; align-items: center; gap: 10px; }
  .trust .check { color: var(--success); font-weight: 700; }
  .sent-ico { font-family: var(--serif); font-size: 46px; color: var(--accent); line-height: 1; margin-bottom: 14px; }
  .sent-h { font-size: 28px; margin-bottom: 10px; }
  .alert.dev code { background: rgba(0,0,0,.08); padding: 1px 5px; border-radius: 3px; }
  .back-link { display: inline-block; margin-top: 20px; }

  @media (max-width: 860px) { .flow-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-signup-form]');
  const cardDefault = document.querySelector<HTMLDivElement>('[data-card-default]');
  const cardSent = document.querySelector<HTMLDivElement>('[data-card-sent]');
  const sentEmail = document.querySelector<HTMLElement>('[data-sent-email]');
  const devFallback = document.querySelector<HTMLDivElement>('[data-dev-fallback]');
  const devLink = document.querySelector<HTMLAnchorElement>('[data-dev-link]');
  const backBtn = document.querySelector<HTMLButtonElement>('[data-back]');
  const submit = form?.querySelector<HTMLButtonElement>('[data-submit]');
  const errorEl = form?.querySelector<HTMLDivElement>('[data-form-error]');
  const lDefault = submit?.querySelector('.l-default') as HTMLElement | null;
  const lLoading = submit?.querySelector('.l-loading') as HTMLElement | null;

  document.querySelectorAll<HTMLButtonElement>('[data-soon]').forEach((b) =>
    b.addEventListener('click', () => alert(b.dataset.soon)));

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submit) return;
    if (errorEl) errorEl.hidden = true;
    submit.disabled = true;
    if (lDefault) lDefault.hidden = true;
    if (lLoading) lLoading.hidden = false;
    const fd = new FormData(form);
    const name = String(fd.get('name') || '').trim();
    // Carry the name across the email round-trip so checkout can prefill + save it.
    if (name) document.cookie = `df_name=${encodeURIComponent(name.slice(0, 120))}; path=/; max-age=86400; samesite=lax`;
    try {
      const res = await fetch('/api/auth/request', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: String(fd.get('email') || '').trim(), next: String(fd.get('next') || '') }),
      });
      const data = await res.json() as { ok?: boolean; error?: string; email?: string; devLink?: string };
      if (!res.ok || !data.ok) throw new Error(data.error || 'Something went wrong.');
      if (sentEmail) sentEmail.textContent = data.email ?? '';
      if (cardDefault) cardDefault.hidden = true;
      if (cardSent) cardSent.hidden = false;
      if (data.devLink && devFallback && devLink) { devFallback.hidden = false; devLink.href = data.devLink; }
    } catch (err) {
      if (errorEl) { errorEl.hidden = false; errorEl.textContent = err instanceof Error ? err.message : 'Network error.'; }
    } finally {
      submit.disabled = false;
      if (lDefault) lDefault.hidden = false;
      if (lLoading) lLoading.hidden = true;
    }
  });
  backBtn?.addEventListener('click', () => {
    if (cardSent) cardSent.hidden = true;
    if (cardDefault) cardDefault.hidden = false;
    if (devFallback) devFallback.hidden = true;
  });
</script>
