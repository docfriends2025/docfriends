---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { HOME_FOR_ROLE } from '~/lib/site';

export const prerender = false;

// Already signed in → straight to their portal.
if (Astro.locals.user) {
  return Astro.redirect(HOME_FOR_ROLE[Astro.locals.user.role] ?? '/dashboard');
}

const errorRaw = Astro.url.searchParams.get('error');
const nextRaw = Astro.url.searchParams.get('next');
const next = (nextRaw && nextRaw.startsWith('/') && !nextRaw.startsWith('//')) ? nextRaw : '';

const errorMessages: Record<string, string> = {
  'missing-token':  'That link was missing its token. Request a new one below.',
  'not-configured': 'Sign-in is not configured on this site yet.',
  'session-failed': 'Could not start your session. Please request a new link.',
};
const error = errorRaw ? (errorMessages[errorRaw] ?? errorRaw) : null;
---

<BaseLayout title="Sign in — DocFriends" description="Sign in to access your cases and opinions." activeNav="/sign-in">
  <section class="signin">
    <div class="container-narrow">
      <header class="si-head">
        <div class="eyebrow">One quick step</div>
        <h1 class="h-display si-title">One tap. <em>Or one email.</em></h1>
        <p class="si-lead muted">We hold your case in a secure account so only you and your assigned doctors can see it. No passwords, ever.</p>
      </header>

      <div class="si-card" data-card-default>
        {error && <div class="alert error" style="margin-bottom:20px">{error}</div>}

        <!-- Social paths (design-complete; email is the live path today) -->
        <div class="social-row">
          <button type="button" class="social-btn" data-soon="Google sign-in is coming soon — use your email below for now.">
            <span class="s-ico">G</span> Continue with Google
          </button>
          <button type="button" class="social-btn" data-soon="Apple sign-in is coming soon — use your email below for now.">
            <span class="s-ico"></span> Continue with Apple
          </button>
        </div>
        <div class="or"><span>or sign in with email</span></div>

        <form data-signin-form>
          <label for="si-email" class="field-label">Your email</label>
          <input id="si-email" name="email" type="email" class="input-line" placeholder="you@email.com" autocomplete="email" required />
          <input type="hidden" name="next" value={next} />
          <button type="submit" class="btn primary lg block" style="margin-top:22px" data-submit>
            <span class="l-default">Send my sign-in link →</span>
            <span class="l-loading" hidden>Sending…</span>
          </button>
          <div class="alert error" data-form-error hidden style="margin-top:14px"></div>
        </form>

        <div class="trust"><span class="check">✓</span><span class="faint tiny">No passwords · No spam · Delete account anytime</span></div>
        <p class="demo faint tiny">Demo accounts: <code>maya@example.com</code> (client) · <code>mehta@example.com</code> (doctor) · <code>sarah@example.com</code> (admin)</p>
      </div>

      <!-- Sent state -->
      <div class="si-card" data-card-sent hidden>
        <div class="sent-ico">✉</div>
        <h2 class="h-display sent-h">Check your email.</h2>
        <p class="muted">We sent a sign-in link to <strong data-sent-email></strong>. It works once, expires in 15 minutes, and lands you right where you were going.</p>
        <div data-dev-fallback hidden style="margin-top:18px">
          <div class="alert dev"><strong>DEV MODE</strong> — no email provider configured. Click below to sign in directly. Set <code>RESEND_API_KEY</code> to send real email.</div>
          <a href="#" class="btn primary lg block" data-dev-link style="margin-top:12px">Click to sign in →</a>
        </div>
        <button type="button" class="btn ghost block" data-back style="margin-top:16px">← Use a different email</button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .signin { padding-block: clamp(36px, 6vw, 72px); }
  .si-head { text-align: center; max-width: 520px; margin: 0 auto 30px; }
  .si-title { font-size: clamp(34px, 5vw, 46px); margin: 12px 0 14px; }
  .si-lead { font-size: 15px; line-height: 1.6; }
  .si-card { max-width: 460px; margin: 0 auto; background: var(--paper); border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 34px 32px; box-shadow: 0 24px 56px -26px rgba(26,34,56,.16); position: relative; }
  .si-card::before { content: ''; position: absolute; inset: -1px -1px auto; height: 4px; background: var(--accent); border-radius: var(--radius) var(--radius) 0 0; }
  .social-row { display: flex; flex-direction: column; gap: 10px; }
  .social-btn { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 13px; border: 1px solid var(--line-strong); border-radius: 10px; background: var(--paper); font-size: 14.5px; font-weight: 500; cursor: pointer; transition: border-color .15s, background .15s; }
  .social-btn:hover { border-color: var(--ink); background: var(--paper-2); }
  .s-ico { width: 20px; height: 20px; display: grid; place-items: center; font-weight: 700; font-family: var(--serif); }
  .or { display: flex; align-items: center; gap: 14px; margin: 20px 0; color: var(--ink-light); font-size: 12px; }
  .or::before, .or::after { content: ''; flex: 1; height: 1px; background: var(--line); }
  .trust { margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--line); display: flex; align-items: center; gap: 10px; }
  .trust .check { color: var(--success); font-weight: 700; }
  .demo { margin-top: 14px; line-height: 1.7; }
  .demo code { background: var(--paper-2); padding: 1px 5px; border-radius: 4px; font-family: var(--mono); font-size: 11px; }
  .sent-ico { font-family: var(--serif); font-size: 46px; color: var(--accent); line-height: 1; margin-bottom: 14px; }
  .sent-h { font-size: 28px; margin-bottom: 10px; }
  .alert.dev code { background: rgba(0,0,0,.08); padding: 1px 5px; border-radius: 3px; }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-signin-form]');
  const cardDefault = document.querySelector<HTMLDivElement>('[data-card-default]');
  const cardSent = document.querySelector<HTMLDivElement>('[data-card-sent]');
  const sentEmail = document.querySelector<HTMLElement>('[data-sent-email]');
  const devFallback = document.querySelector<HTMLDivElement>('[data-dev-fallback]');
  const devLink = document.querySelector<HTMLAnchorElement>('[data-dev-link]');
  const backBtn = document.querySelector<HTMLButtonElement>('[data-back]');
  const submit = form?.querySelector<HTMLButtonElement>('[data-submit]');
  const errorEl = form?.querySelector<HTMLDivElement>('[data-form-error]');
  const lDefault = submit?.querySelector('.l-default') as HTMLElement | null;
  const lLoading = submit?.querySelector('.l-loading') as HTMLElement | null;

  document.querySelectorAll<HTMLButtonElement>('[data-soon]').forEach((b) =>
    b.addEventListener('click', () => alert(b.dataset.soon)));

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submit) return;
    if (errorEl) errorEl.hidden = true;
    submit.disabled = true;
    if (lDefault) lDefault.hidden = true;
    if (lLoading) lLoading.hidden = false;
    const fd = new FormData(form);
    try {
      const res = await fetch('/api/auth/request', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: String(fd.get('email') || '').trim(), next: String(fd.get('next') || '') }),
      });
      const data = await res.json() as { ok?: boolean; error?: string; email?: string; devLink?: string };
      if (!res.ok || !data.ok) throw new Error(data.error || 'Something went wrong.');
      if (sentEmail) sentEmail.textContent = data.email ?? '';
      if (cardDefault) cardDefault.hidden = true;
      if (cardSent) cardSent.hidden = false;
      if (data.devLink && devFallback && devLink) { devFallback.hidden = false; devLink.href = data.devLink; }
    } catch (err) {
      if (errorEl) { errorEl.hidden = false; errorEl.textContent = err instanceof Error ? err.message : 'Network error.'; }
    } finally {
      submit.disabled = false;
      if (lDefault) lDefault.hidden = false;
      if (lLoading) lLoading.hidden = true;
    }
  });
  backBtn?.addEventListener('click', () => {
    if (cardSent) cardSent.hidden = true;
    if (cardDefault) cardDefault.hidden = false;
    if (devFallback) devFallback.hidden = true;
  });
</script>
