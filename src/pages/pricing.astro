---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getEnv } from '~/lib/db';
import { getPackages } from '~/lib/content';
import { formatUSD } from '~/lib/format';

export const prerender = false;
const packages = await getPackages(getEnv(Astro.locals));
const dots = (n: number, max = 5) => Array.from({ length: max }, (_, i) => i < n);
---

<BaseLayout title="Pricing — DocFriends" description="One-time pricing. Single, Council, or Board — pick how many doctors review your case." activeNav="/pricing">
  <section class="pricing">
    <div class="container">
      <header class="p-head">
        <div class="eyebrow">Pricing</div>
        <h1 class="h-display p-title">How many doctors <em>should look?</em></h1>
        <p class="muted">One-time, per case. You only pay when you choose a panel — describing your case and uploading reports is free.</p>
      </header>

      <div class="p-grid">
        {packages.map((pkg) => (
          <div class:list={['p-card', { featured: pkg.featured }]}>
            {pkg.featured && <span class="badge">Most chosen</span>}
            <h2 class="h-display p-name">{pkg.name}</h2>
            <p class="muted p-blurb">{pkg.blurb}</p>
            <div class="dots">{dots(pkg.opinionCount).map((on) => <span class:list={['dot', { on }]}>{on ? '⚕' : ''}</span>)}</div>
            <div class="faint tiny">{pkg.opinionCount} doctor opinion{pkg.opinionCount > 1 ? 's' : ''}</div>
            <div class="p-price h-display">{formatUSD(pkg.priceCents)}</div>
            <div class="faint tiny">one-time · refund if late</div>
            <a href="/case/start" class:list={['btn', pkg.featured ? 'primary' : 'ghost', 'block']} style="margin-top:20px">Choose {pkg.name} →</a>
          </div>
        ))}
      </div>

      <ul class="includes">
        <li>✓ Written opinions delivered within 24 hours</li>
        <li>✓ Board-certified specialists, vetted</li>
        <li>✓ Full refund if we miss the 24-hour window</li>
        <li>✓ Optional teleconsult with any reviewing doctor</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .pricing { padding-block: clamp(36px, 5vw, 64px); }
  .p-head { max-width: 560px; margin-bottom: 44px; }
  .p-title { font-size: clamp(36px, 5vw, 54px); margin: 12px 0 14px; }
  .p-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .p-card { position: relative; border: 1px solid var(--line); border-radius: 16px; padding: 30px 26px; background: var(--paper); }
  .p-card.featured { border-color: var(--ink); box-shadow: 0 24px 56px -30px rgba(26,34,56,.2); }
  .badge { position: absolute; top: -11px; left: 26px; background: var(--accent-tint); color: var(--accent-deep); border: 1px solid var(--accent-soft); font-size: 11px; font-weight: 600; padding: 3px 12px; border-radius: 99px; }
  .p-name { font-size: 26px; }
  .p-blurb { font-size: 14px; margin: 4px 0 18px; }
  .dots { display: flex; gap: 7px; margin-bottom: 8px; }
  .dot { width: 26px; height: 26px; border-radius: 50%; border: 1px solid var(--line-strong); display: grid; place-items: center; font-size: 12px; color: var(--ink-light); }
  .dot.on { background: var(--ink); border-color: var(--ink); color: var(--paper); }
  .p-price { font-size: 40px; margin-top: 18px; }
  .includes { list-style: none; padding: 0; margin: 44px 0 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; max-width: 640px; color: var(--ink-soft); font-size: 14px; }
  @media (max-width: 820px) { .p-grid { grid-template-columns: 1fr; max-width: 420px; } .includes { grid-template-columns: 1fr; } }
</style>
