---
interface Props { size?: number; }
const { size = 30 } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 32 32" aria-hidden="true" class="brandmark">
  <circle cx="16" cy="16" r="15" fill="var(--ink)"/>
  <rect x="9" y="15" width="14" height="2" rx="1" fill="var(--paper)"/>
  <rect x="15" y="9" width="2" height="14" rx="1" fill="var(--paper)"/>
</svg>
<style>.brandmark { flex-shrink: 0; }</style>
