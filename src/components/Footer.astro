---
import BrandMark from './BrandMark.astro';
import { SITE } from '~/lib/site';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand"><BrandMark size={26} /><span>{SITE.name}</span></a>
      <p class="footer-tag">{SITE.tagline}</p>
      <p class="footer-mini faint">Specialist second opinions · delivered in 24 hours.</p>
    </div>
    <div class="footer-cols">
      <div class="footer-col">
        <div class="eyebrow ink">Product</div>
        <a href="/case/start">Start a case</a>
        <a href="/pricing">Pricing</a>
        <a href="/find-a-specialist">Find a specialist</a>
        <a href="/faqs">FAQs</a>
        <a href="/journal">Journal</a>
      </div>
      <div class="footer-col">
        <div class="eyebrow ink">Company</div>
        <a href="/contact">Contact</a>
        <a href="/for-physicians">For physicians</a>
        <a href={`mailto:${SITE.pressEmail}`}>Press</a>
      </div>
      <div class="footer-col">
        <div class="eyebrow ink">Legal</div>
        <a href="/terms">Terms &amp; Conditions</a>
        <a href="/privacy">Privacy Policy</a>
        <a href="/refund-policy">Refund &amp; Cancellation</a>
        <a href="/shipping-policy">Shipping &amp; Delivery</a>
      </div>
      <div class="footer-col">
        <div class="eyebrow ink">Get in touch</div>
        <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
        <span class="faint tiny">{SITE.legalEntity}</span>
        <span class="faint tiny">{SITE.city}, {SITE.region}, {SITE.country}</span>
      </div>
    </div>
  </div>

  <div class="container footer-disclaimer">
    <p class="faint tiny">{SITE.medicalDisclaimer}</p>
  </div>

  <div class="container footer-base">
    <span class="faint tiny">© {year} {SITE.name} · {SITE.legalEntity}.</span>
    <span class="faint tiny footer-legal">
      <a href="/privacy">Privacy</a> · <a href="/terms">Terms</a> ·
      <a href="/refund-policy">Refund</a> · <a href="/shipping-policy">Shipping</a>
    </span>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--line); background: var(--paper-2); margin-top: 80px; }
  .footer-inner { display: grid; grid-template-columns: 1.4fr 2.2fr; gap: 48px; padding-block: 54px 32px; }
  .brand { font-family: var(--serif); font-size: 22px; display: inline-flex; align-items: center; gap: 9px; }
  .footer-tag { font-family: var(--serif); font-size: 19px; line-height: 1.3; margin-top: 14px; max-width: 320px; }
  .footer-mini { margin-top: 8px; font-size: 13px; }
  .footer-cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col .eyebrow { margin-bottom: 4px; }
  .footer-col a { font-size: 13.5px; color: var(--ink-soft); }
  .footer-col a:hover { color: var(--accent); }
  .footer-disclaimer { padding-block: 16px; border-top: 1px solid var(--line); }
  .footer-disclaimer p { line-height: 1.55; max-width: 880px; }
  .footer-base { display: flex; justify-content: space-between; padding-block: 16px 28px; border-top: 1px solid var(--line); flex-wrap: wrap; gap: 8px; }
  .footer-legal a { color: var(--ink-soft); }
  .footer-legal a:hover { color: var(--accent); }
  @media (max-width: 860px) { .footer-inner { grid-template-columns: 1fr; gap: 32px; } .footer-cols { grid-template-columns: 1fr 1fr; } }
</style>
