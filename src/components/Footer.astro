---
import BrandMark from './BrandMark.astro';
import { SITE } from '~/lib/site';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand"><BrandMark size={26} /><span>{SITE.name}</span></a>
      <p class="footer-tag">{SITE.tagline}</p>
      <p class="footer-mini faint">Specialist second opinions · delivered in 24 hours.</p>
    </div>
    <div class="footer-cols">
      <div class="footer-col">
        <div class="eyebrow ink">Product</div>
        <a href="/case/start">Start a case</a>
        <a href="/pricing">Pricing</a>
        <a href="/faqs">FAQs</a>
        <a href="/journal">Journal</a>
      </div>
      <div class="footer-col">
        <div class="eyebrow ink">Company</div>
        <a href="/contact">Contact</a>
        <a href={`mailto:${SITE.doctorsEmail}`}>Join as a doctor</a>
        <a href={`mailto:${SITE.pressEmail}`}>Press</a>
      </div>
      <div class="footer-col">
        <div class="eyebrow ink">Get in touch</div>
        <a href={`mailto:${SITE.supportEmail}`}>{SITE.supportEmail}</a>
        <span class="faint tiny">{SITE.office}</span>
      </div>
    </div>
  </div>
  <div class="container footer-base">
    <span class="faint tiny">© {year} {SITE.name}. For informational purposes; not a substitute for emergency care.</span>
    <span class="faint tiny">Privacy · Terms</span>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--line); background: var(--paper-2); margin-top: 80px; }
  .footer-inner { display: grid; grid-template-columns: 1.4fr 2fr; gap: 48px; padding-block: 54px 36px; }
  .brand { font-family: var(--serif); font-size: 22px; display: inline-flex; align-items: center; gap: 9px; }
  .footer-tag { font-family: var(--serif); font-size: 19px; line-height: 1.3; margin-top: 14px; max-width: 320px; }
  .footer-mini { margin-top: 8px; font-size: 13px; }
  .footer-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col .eyebrow { margin-bottom: 4px; }
  .footer-col a { font-size: 13.5px; color: var(--ink-soft); }
  .footer-col a:hover { color: var(--accent); }
  .footer-base { display: flex; justify-content: space-between; padding-block: 18px 28px; border-top: 1px solid var(--line); flex-wrap: wrap; gap: 8px; }
  @media (max-width: 760px) { .footer-inner { grid-template-columns: 1fr; gap: 32px; } .footer-cols { grid-template-columns: 1fr 1fr; } }
</style>
